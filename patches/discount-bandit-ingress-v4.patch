diff --git a/app/Http/Middleware/TrustIngressPath.php b/app/Http/Middleware/TrustIngressPath.php
new file mode 100644
index 0000000..6ad62de
--- /dev/null
+++ b/app/Http/Middleware/TrustIngressPath.php
@@ -0,0 +1,190 @@
+<?php
+
+namespace App\Http\Middleware;
+
+use App\Models\User;
+use Closure;
+use Illuminate\Http\Request;
+use Illuminate\Support\Facades\Log;
+use Illuminate\Support\Facades\URL;
+use Illuminate\Support\Str;
+use Symfony\Component\HttpFoundation\Response;
+
+class TrustIngressPath
+{
+    public function handle(Request $request, Closure $next): Response
+    {
+        $context = $this->resolveIngressContext($request);
+
+        if ($context !== null) {
+            $this->applyBaseUrl($context);
+        }
+
+        if ($context !== null && $this->shouldLogRequest($request)) {
+            Log::info('Discount Bandit ingress request', $this->buildLogContext($request, $context));
+        }
+
+        $response = $next($request);
+
+        if ($context !== null && $this->shouldLogRequest($request)) {
+            Log::info('Discount Bandit ingress response', array_merge(
+                $this->buildLogContext($request, $context),
+                [
+                    'status' => $response->getStatusCode(),
+                    'location' => $response->headers->get('Location'),
+                    'is_redirect' => $response->isRedirection(),
+                ]
+            ));
+        }
+
+        if ($context !== null) {
+            $this->rewriteIngressAwareMarkup($response, $context);
+        }
+
+        return $response;
+    }
+
+    protected function resolveIngressContext(Request $request): ?array
+    {
+        $scheme = $request->headers->get('X-Forwarded-Proto') ?: $request->getScheme();
+        $host = $request->headers->get('X-Forwarded-Host') ?: $request->getHttpHost();
+        $ingressPath = trim((string) $request->headers->get('X-Ingress-Path', ''), " \t\n\r\0\x0B");
+
+        if ($host === '') {
+            return null;
+        }
+
+        $normalizedIngressPath = $ingressPath === ''
+            ? ''
+            : '/'.trim($ingressPath, '/');
+
+        return [
+            'base_url' => rtrim(sprintf('%s://%s%s', $scheme, $host, $normalizedIngressPath), '/'),
+            'host' => $host,
+            'ingress_path' => $normalizedIngressPath,
+            'scheme' => $scheme,
+        ];
+    }
+
+    protected function applyBaseUrl(array $context): void
+    {
+        $baseUrl = $context['base_url'];
+        $cookiePath = $context['ingress_path'] === ''
+            ? '/'
+            : $context['ingress_path'];
+
+        URL::forceRootUrl($baseUrl);
+        URL::forceScheme(parse_url($baseUrl, PHP_URL_SCHEME) ?: 'http');
+
+        config([
+            'app.url' => $baseUrl,
+            'app.asset_url' => $baseUrl,
+            'livewire.asset_url' => $baseUrl.'/livewire/livewire.js',
+            'filesystems.disks.public.url' => $baseUrl.'/storage',
+            'filesystems.disks.store.url' => $baseUrl.'/storage/store',
+            'session.path' => $cookiePath,
+            'session.secure' => $context['scheme'] === 'https',
+            'session.same_site' => $context['ingress_path'] === '' ? config('session.same_site') : 'none',
+            'session.partitioned' => $context['ingress_path'] !== '',
+        ]);
+    }
+
+    protected function shouldLogRequest(Request $request): bool
+    {
+        return $request->is('login')
+            || $request->is('register')
+            || $request->is('livewire/*')
+            || $request->is('products*')
+            || $request->path() === '/';
+    }
+
+    protected function rewriteIngressAwareMarkup(Response $response, array $context): void
+    {
+        $contentType = (string) $response->headers->get('Content-Type', '');
+
+        if (! Str::contains($contentType, 'text/html')) {
+            return;
+        }
+
+        $content = $response->getContent();
+
+        if (! is_string($content) || $content === '') {
+            return;
+        }
+
+        $ingressPath = $context['ingress_path'];
+        $baseUrl = $context['base_url'];
+        $hostRoot = $context['scheme'].'://'.$context['host'];
+        $homeUrl = $baseUrl.'/products';
+
+        if ($ingressPath === '') {
+            return;
+        }
+
+        $rewritten = str_replace(
+            [
+                $hostRoot.'/livewire/',
+                $hostRoot.'/storage/',
+                'http://localhost/storage/',
+                ' href="'.$hostRoot.'/"',
+                ' href="'.$hostRoot.'"',
+                " href='".$hostRoot."/'",
+                " href='".$hostRoot."'",
+                '"/livewire/',
+                '"/storage/',
+                "'/livewire/",
+                "'/storage/",
+                ' href="/"',
+                " href='/'",
+                ' src="/livewire/',
+                ' src="/storage/',
+                ' data-update-uri="/livewire/',
+            ],
+            [
+                $baseUrl.'/livewire/',
+                $baseUrl.'/storage/',
+                $baseUrl.'/storage/',
+                ' href="'.$homeUrl.'"',
+                ' href="'.$homeUrl.'"',
+                " href='".$homeUrl."'",
+                " href='".$homeUrl."'",
+                '"'.$ingressPath.'/livewire/',
+                '"'.$ingressPath.'/storage/',
+                "'".$ingressPath.'/livewire/',
+                "'".$ingressPath.'/storage/',
+                ' href="'.$homeUrl.'"',
+                " href='".$homeUrl."'",
+                ' src="'.$ingressPath.'/livewire/',
+                ' src="'.$ingressPath.'/storage/',
+                ' data-update-uri="'.$ingressPath.'/livewire/',
+            ],
+            $content
+        );
+
+        if ($rewritten !== $content) {
+            $response->setContent($rewritten);
+        }
+    }
+
+    protected function buildLogContext(Request $request, array $context): array
+    {
+        return [
+            'method' => $request->getMethod(),
+            'path' => '/'.ltrim($request->path(), '/'),
+            'route_name' => $request->route()?->getName(),
+            'host' => $context['host'],
+            'scheme' => $context['scheme'],
+            'ingress_path' => $context['ingress_path'],
+            'base_url' => $context['base_url'],
+            'livewire_asset_url' => config('livewire.asset_url'),
+            'users_exist' => User::exists(),
+            'authenticated' => $request->user() !== null,
+            'has_livewire_header' => $request->headers->has('X-Livewire'),
+            'session_id' => $request->hasSession() ? $request->session()->getId() : null,
+            'session_cookie_path' => config('session.path'),
+            'session_same_site' => config('session.same_site'),
+            'session_partitioned' => config('session.partitioned'),
+            'intended_url' => $request->hasSession() ? $request->session()->get('url.intended') : null,
+        ];
+    }
+}
